# ReqSense AI — Backend Environment Variables
# Copy this to .env and fill in all required values before starting the server.
# The server will refuse to start if any required field is missing or invalid.

# ── Database ──────────────────────────────────────────────────────────────────
# IMPORTANT: prefix must be postgresql+asyncpg:// (not postgresql://)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/reqsense

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Groq ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=15

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_TIMEOUT_SECONDS=5
FROM_EMAIL=noreply@reqsense.ai

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_super_secret_jwt_key_min_32_chars_replace_this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
STREAM_TOKEN_EXPIRE_SECONDS=60

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_MODE=hosted
CHROMA_API_KEY=your_chroma_cloud_key
CHROMA_TENANT=your_tenant
CHROMA_DATABASE=reqsense
# Only used when CHROMA_MODE=local:
CHROMA_PERSIST_DIRECTORY=/data/chroma_db
CHROMA_TIMEOUT_SECONDS=10

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_VERSION=v1

# ── Object Storage (Cloudflare R2 or AWS S3) ──────────────────────────────────
S3_BUCKET_NAME=reqsense-srs-docs
S3_ACCESS_KEY_ID=your_key
S3_SECRET_ACCESS_KEY=your_secret
# For Cloudflare R2: https://<account-id>.r2.cloudflarestorage.com
# For AWS S3: leave blank
S3_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
S3_REGION=auto
S3_TIMEOUT_SECONDS=10

# ── Sentry ────────────────────────────────────────────────────────────────────
# Leave blank to disable Sentry (safe for local dev)
SENTRY_DSN=your_sentry_dsn

# ── CORS / Frontend ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# ── Rate limits ───────────────────────────────────────────────────────────────
RATE_LIMIT_MESSAGES_PER_MINUTE=30
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_ANALYTICS_PER_MINUTE=100
RATE_LIMIT_DOWNLOADS_PER_MINUTE=20

# ── Misc ──────────────────────────────────────────────────────────────────────
PROMPT_VERSION=v1.0
# 'development' exposes /docs and /redoc; 'production' hides them
ENV=development
